#include <physical_layouts.dtsi>

/ {
    leeloo_physical_layout: leeloo_physical_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys
            /* Row 0 */
            = <&key_physical_attrs 100 100 0 10 0 0 0> /* SW1 L */
            , <&key_physical_attrs 100 100 100 5 0 0 0> /* SW2 L */
            , <&key_physical_attrs 100 100 200 0 0 0 0> /* SW3 L */
            , <&key_physical_attrs 100 100 300 5 0 0 0> /* SW4 L */
            , <&key_physical_attrs 100 100 400 15 0 0 0> /* SW5 L */
            , <&key_physical_attrs 100 100 500 20 0 0 0> /* SW6 L */

            , <&key_physical_attrs 100 100 800 20 0 0 0> /* SW6 R */
            , <&key_physical_attrs 100 100 900 15 0 0 0> /* SW5 R */
            , <&key_physical_attrs 100 100 1000 5 0 0 0> /* SW4 R */
            , <&key_physical_attrs 100 100 1100 0 0 0 0> /* SW3 R */
            , <&key_physical_attrs 100 100 1200 5 0 0 0> /* SW2 R */
            , <&key_physical_attrs 100 100 1300 10 0 0 0> /* SW1 R */

            /* Row 1 */
            , <&key_physical_attrs 100 100 0 110 0 0 0>
            , <&key_physical_attrs 100 100 100 105 0 0 0>
            , <&key_physical_attrs 100 100 200 100 0 0 0>
            , <&key_physical_attrs 100 100 300 105 0 0 0>
            , <&key_physical_attrs 100 100 400 115 0 0 0>
            , <&key_physical_attrs 100 100 500 120 0 0 0>

            , <&key_physical_attrs 100 100 800 120 0 0 0>
            , <&key_physical_attrs 100 100 900 115 0 0 0>
            , <&key_physical_attrs 100 100 1000 105 0 0 0>
            , <&key_physical_attrs 100 100 1100 100 0 0 0>
            , <&key_physical_attrs 100 100 1200 105 0 0 0>
            , <&key_physical_attrs 100 100 1300 110 0 0 0>

            /* Row 2 */
            , <&key_physical_attrs 100 100 0 210 0 0 0>
            , <&key_physical_attrs 100 100 100 205 0 0 0>
            , <&key_physical_attrs 100 100 200 200 0 0 0>
            , <&key_physical_attrs 100 100 300 205 0 0 0>
            , <&key_physical_attrs 100 100 400 215 0 0 0>
            , <&key_physical_attrs 100 100 500 220 0 0 0>

            , <&key_physical_attrs 100 100 800 220 0 0 0>
            , <&key_physical_attrs 100 100 900 215 0 0 0>
            , <&key_physical_attrs 100 100 1000 205 0 0 0>
            , <&key_physical_attrs 100 100 1100 200 0 0 0>
            , <&key_physical_attrs 100 100 1200 205 0 0 0>
            , <&key_physical_attrs 100 100 1300 210 0 0 0>

            /* Row 3 */
            , <&key_physical_attrs 100 100 0 310 0 0 0>
            , <&key_physical_attrs 100 100 100 305 0 0 0>
            , <&key_physical_attrs 100 100 200 300 0 0 0>
            , <&key_physical_attrs 100 100 300 305 0 0 0>
            , <&key_physical_attrs 100 100 400 315 0 0 0>
            , <&key_physical_attrs 100 100 500 320 0 0 0>
            , <&key_physical_attrs 100 100 600 350 0 0 0> /* SW29 L */

            , <&key_physical_attrs 100 100 700 350 0 0 0> /* SW29 R */
            , <&key_physical_attrs 100 100 800 320 0 0 0>
            , <&key_physical_attrs 100 100 900 315 0 0 0>
            , <&key_physical_attrs 100 100 1000 305 0 0 0>
            , <&key_physical_attrs 100 100 1100 300 0 0 0>
            , <&key_physical_attrs 100 100 1200 305 0 0 0>
            , <&key_physical_attrs 100 100 1300 310 0 0 0>

            /* Row 4 (Thumb) */
            , <&key_physical_attrs 100 100 250 410 0 0 0> /* SW25 L */
            , <&key_physical_attrs 100 100 350 420 0 0 0> /* SW26 L */
            , <&key_physical_attrs 100 100 450 430 0 0 0> /* SW27 L */
            , <&key_physical_attrs 100 100 550 440 0 0 0> /* SW28 L */

            , <&key_physical_attrs 100 100 750 440 0 0 0> /* SW28 R */
            , <&key_physical_attrs 100 100 850 430 0 0 0> /* SW27 R */
            , <&key_physical_attrs 100 100 950 420 0 0 0> /* SW26 R */
            , <&key_physical_attrs 100 100 1050 410 0 0 0> /* SW25 R */
            ;
    };
};
